# GitHub token for the live activity heatmap (optional; unauth requests are rate-limited).
# Create a fine-grained PAT with public-repo read access.
GITHUB_TOKEN=

# GitHub handle to pull commits/activity from.
NEXT_PUBLIC_GITHUB_USERNAME=d8barcelos

# Spotify now-playing (optional; v2 feature). Leaving these empty falls back to data/now.ts.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Site URL (used for OG/sitemap/robots).
NEXT_PUBLIC_SITE_URL=https://diogobarcelos.dev
